{
  "name": "gons-job",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "module": "src/cli.ts",
  "bin": {
    "job": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "build": "bun build --compile --target=bun src/cli.ts --outfile=dist/job",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ink": "^5.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "typescript": "^5.6.3",
    "@types/bun": "latest"
  }
}
